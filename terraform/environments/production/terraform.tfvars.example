# Example variable values for the production environment.
# Copy to terraform.tfvars and adjust. Never commit real terraform.tfvars.

environment             = "production"
owner                   = "platform-team"
aws_region              = "us-east-1"
availability_zone_count = 2
additional_tags = {
  CostCenter      = "prod-security-5678"
  Confidentiality = "restricted"
}

# Harden the firewall in production.
firewall_delete_protection           = true
firewall_subnet_change_protection    = true
firewall_policy_change_protection    = true
stateful_rule_order                  = "STRICT_ORDER"

# Logging and monitoring.
enable_firewall_cloudwatch_logs = true
enable_firewall_s3_archival     = true
firewall_log_retention_days     = 90