# Enforce consistent line endings and binary handling across platforms/CI.
# The Makefile, shell scripts, and Python files require LF line endings.

* text=auto eol=lf

# Source files always use LF
*.tf          text eol=lf
*.hcl         text eol=lf
*.tftpl       text eol=lf
*.py          text eol=lf
*.sh          text eol=lf
*.bash        text eol=lf
Makefile      text eol=lf
*.mk          text eol=lf

# Config / docs
*.yml         text eol=lf
*.yaml        text eol=lf
*.json        text eol=lf
*.md          text eol=lf
*.txt         text eol=lf
*.mmd         text eol=lf
*.tfvars      text eol=lf
*.tfvars.example text eol=lf
.editorconfig text eol=lf
.gitignore    text eol=lf
.gitattributes text eol=lf
LICENSE       text eol=lf

# Binary files
*.png         binary
*.jpg         binary
*.jpeg        binary
*.gif         binary
*.pdf         binary
*.pem         binary
*.key         binary
