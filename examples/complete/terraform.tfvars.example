# Complete example: HA inspection across 2 AZs, CloudWatch + S3 logging,
# monitoring with SNS, and optional test workloads for traffic validation.
# Deploy from terraform/ with: terraform init && terraform apply

environment             = "lab"
owner                   = "platform-team"
aws_region              = "us-east-1"
availability_zone_count = 2

stateful_rule_order        = "STRICT_ORDER"
firewall_log_retention_days = 30
enable_firewall_cloudwatch_logs = true
enable_firewall_s3_archival     = true
enable_monitoring_sns           = true

# Enable only during traffic validation; disable to avoid cost.
enable_test_workloads = false
test_instance_type    = "t3.micro"

additional_tags = {
  CostCenter = "lab-security-1234"
}