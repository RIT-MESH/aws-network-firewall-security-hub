# Allowed stateful traffic (pass rules). Non-HTTP allow rules; HTTP/HTTPS egress
# is governed by the allowed-domains ALLOWLIST rule group.
#
# Variables are defined as firewall policy rule variables:
#   $LAB_HOME_NET    - workload VPCs (production, development, shared services)
#   $LAB_PROD_NET    - production VPC CIDR
#   $LAB_SHARED_NET - shared services VPC CIDR
#   $LAB_EXTERNAL_NET - 0.0.0.0/0

# Management subnet (shared services) -> production SSH
pass tcp $LAB_SHARED_NET any -> $LAB_PROD_NET 22 (
    msg: "LAB allow shared-services management to production SSH";
    flow: to_server;
    sid: 10000010;
    rev: 1;
)

# Production -> shared services approved logging port (e.g., syslog/TCP 514)
pass tcp $LAB_PROD_NET any -> $LAB_SHARED_NET 514 (
    msg: "LAB allow production to shared services logging";
    flow: to_server;
    sid: 10000011;
    rev: 1;
)

# Production -> internet HTTPS is allowed only via the allowed-domains ALLOWLIST
# (no broad pass rule here on purpose).