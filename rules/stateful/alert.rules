# Alert-only stateful rules for suspicious but not explicitly blocked traffic.
# AWS Network Firewall requires each Suricata rule on a single line.

alert tcp $LAB_HOME_NET any -> $LAB_EXTERNAL_NET [4444,5555,6667] (msg: "LAB suspicious outbound destination port"; flow: to_server; sid: 10000030; rev: 1;)
alert tcp $LAB_HOME_NET any -> $LAB_EXTERNAL_NET 3389 (msg: "LAB outbound RDP attempt detected"; flow: to_server; sid: 10000031; rev: 1;)
