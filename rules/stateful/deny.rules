# Denied stateful traffic (drop rules). Drop actions also generate alert/flow logs.
# Variables: $LAB_DEV_NET, $LAB_PROD_NET, $LAB_HOME_NET, $LAB_EXTERNAL_NET, $LAB_BLOCKED_DESTS
# AWS Network Firewall requires each Suricata rule on a single line.

drop tcp $LAB_DEV_NET any -> $LAB_PROD_NET 22 (msg: "LAB unauthorized Development to Production SSH blocked"; flow: to_server; sid: 10000020; rev: 1;)
drop tcp $LAB_DEV_NET any -> $LAB_PROD_NET any (msg: "LAB block Development to Production application ports by default"; flow: to_server; sid: 10000021; rev: 1;)
drop tcp $LAB_HOME_NET any -> $LAB_EXTERNAL_NET 23 (msg: "LAB outbound Telnet blocked"; flow: to_server; sid: 10000022; rev: 1;)
drop udp $LAB_HOME_NET any -> $LAB_EXTERNAL_NET 53 (msg: "LAB unauthorized external DNS resolver blocked UDP"; sid: 10000023; rev: 1;)
drop ip $LAB_HOME_NET any -> $LAB_BLOCKED_DESTS any (msg: "LAB known prohibited destination IP set blocked"; sid: 10000024; rev: 1;)
drop tcp $LAB_HOME_NET any -> $LAB_EXTERNAL_NET 53 (msg: "LAB unauthorized external DNS resolver blocked TCP"; flow: to_server; sid: 10000025; rev: 1;)
